# Evo Framework — Environment Configuration
# Copy to ~/.openclaw/evo/.env and customize
#
# Prerequisites:
#   Required: python3 (3.7+), bash (4+)
#   Optional: gh (GitHub CLI), rsync, openclaw, claude, codex, gemini
#   Runners use different CLI tools — only install the ones you need.

# Base directory (default: ~/.openclaw/evo)
# EVO_ROOT=$HOME/.openclaw/evo

# Discord notifications (optional)
# EVO_DISCORD_CHANNEL=1234567890
# EVO_MENTION=<@YOUR_USER_ID>

# GitHub archive repo (optional, requires `gh` CLI authenticated)
# EVO_ARCHIVE_REPO=username/evo-instances

# OpenClaw workspace path (default: ~/.openclaw/workspace)
# OPENCLAW_WORKSPACE=$HOME/.openclaw/workspace
